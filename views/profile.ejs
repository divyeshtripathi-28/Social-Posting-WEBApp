<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block" href="http://localhost:8080/logout">Logout</a>
        </div>
        <h3 class="text-3xl mb-5">Hello, <%= user.name %> 👋🏻</h3>
        <h5 class="mb-5">You can create a new post</h5>
        <form method="post" action="/post">
            <textarea name="content" class="py-2 px-5 resize-none bg-transparent border-2 border-zinc-500 rounded-md w-2/5 block mb-3 outline-none" placeholder="What's on your mind ?" ></textarea>
            <input type="submit" class="w-40 px-3 py-2 bg-blue-500 block rounded-md" value="Create new post">
        </form>
        <h3 class="mt-20 text-2xl text-zinc-300 mb-5">Your Posts</h3>
        <div class="post-container">
            <% for(post of user.posts) { %>
            <div class="post w-1/3 p-3 border-[1px] border-zinc-500 rounded-md mb-2">
                <h5 class="text-blue-500">@<%= user.username %></h5>
                <p><%= post.content %></p>
                <small class="mt-2 inline-block text-sm"><%= post.likes.length %> likes</small>
                <a href="/like/<%= post._id %>" class="text-red-500 ml-3">
                    <%= post.likes.indexOf(user._id) === -1 ? "Like": "Unlike" %>
                </a>
                <a href="/edit/<%= post._id %>" class="ml-3 text-zinc-500 ">Edit</a>
            </div>
            <% } %>
        </div>
    </div>
</body>
</html>