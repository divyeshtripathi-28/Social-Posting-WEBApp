<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-3xl mb-5">Create Account</h3>
        <form method="post" action="/register">
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-500 rounded-md" type="text" placeholder="name" name="name">
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-500 rounded-md" type="text" name="username" placeholder="username">
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-500 rounded-md" type="number" name="age" placeholder="age">
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-500 rounded-md" type="email" name="email" placeholder="email">
            <input class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-500 rounded-md" type="password" name="password" placeholder="password">
            <input class="px-5 py-2 outline-none bg-blue-500 rounded-md " type="submit" value="Create Account">
            <a href="/login" class="w-full px-5 py-3 ml-1 text-black bg-yellow-500 rounded-md">Login</a>
        </form>
    </div>
</body>
</html>