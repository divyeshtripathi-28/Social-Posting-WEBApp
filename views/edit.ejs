<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h5 class="mb-5 text-2xl">Edit Your Post</h5>
        <form method="post" action="/update/<%= post._id %>">
            <textarea name="content" class="py-2 px-5 resize-none bg-transparent border-2 border-zinc-500 rounded-md w-2/5 block mb-3 outline-none" placeholder="What's on your mind ?" ><%= post.content %></textarea>
            <input type="submit" class="w-40 px-3 py-2 bg-yellow-500 block text-black rounded-md" value="Update post">
        </form>
    </div>
</body>
</html>